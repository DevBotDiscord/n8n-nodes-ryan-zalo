{
	"name": "n8n-nodes-ryan-zalo",
	"version": "1.0.7",
	"description": "n8n-nodes-ryan-zalo - n8n community nodes for Zalo automation. Send messages, manage groups/users, QR login, webhook triggers for messages/friends/group events, polls, tags. Uses zalo-api-final.",
	"keywords": [
		"n8n-community-node-package",
		"n8n-nodes",
		"n8n-automation",
		"n8n-workflow",
		"zalo-automation",
		"zalo-nodes",
		"zalo-n8n",
		"zalo-api-final",
		"zalo-workflow",
		"zalo-integration",
		"zalo-chatbot",
		"zalo-marketing",
		"zalo-crm",
		"zalo-trigger",
		"zalo-webhook",
		"zalo-qr-login",
		"zalo-message-trigger",
		"zalo-friend-trigger",
		"zalo-group-event-trigger",
		"zalo-poll",
		"zalo-tag",
		"community-nodes",
		"no-code-automation",
		"visual-workflow",
		"business-automation",
		"zalo"
	],
	"license": "MIT",
	"homepage": "https://github.com/DevBotDiscord/n8n-nodes-ryan-zalo",
	"author": {
		"name": "DevBotDiscord",
		"email": "quandev2k7@gmail.com",
		"url": "https://github.com/DevBotDiscord"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/DevBotDiscord/n8n-nodes-ryan-zalo.git"
	},
	"engines": {
		"node": ">=18.10",
		"pnpm": ">=9.1"
	},
	"packageManager": "pnpm@9.1.4",
	"main": "index.js",
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"build": "tsc && gulp build:icons",
		"dev": "tsc --watch",
		"format": "prettier nodes --write",
		"lint": "eslint nodes package.json",
		"lintfix": "eslint nodes package.json --fix",
		"prepublishOnly": "pnpm build && pnpm lint -c .eslintrc.prepublish.js nodes credentials package.json",
		"watch": "concurrently \"pnpm run watch\" \"pnpm run start:n8n\"",
		"start:n8n": "nodemon --watch dist --exec \"npx n8n start\""
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/N8nZaloApi.credentials.js",
			"dist/credentials/ZaloApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/ZaloLoginByQr/ZaloLoginByQr.node.js",
			"dist/nodes/ZaloSendMessage/ZaloSendMessage.node.js",
			"dist/nodes/ZaloUser/ZaloUser.node.js",
			"dist/nodes/ZaloGroup/ZaloGroup.node.js",
			"dist/nodes/ZaloMessageTrigger/ZaloMessageTrigger.node.js",
			"dist/nodes/ZaloFriendTrigger/ZaloFriendTrigger.node.js",
			"dist/nodes/ZaloPoll/ZaloPoll.node.js",
			"dist/nodes/ZaloTag/ZaloTag.node.js",
			"dist/nodes/ZaloGroupEventTrigger/ZaloGroupEventTrigger.node.js",
			"dist/nodes/ZaloUnifiedTrigger/ZaloUnifiedTrigger.node.js"
		]
	},
	"devDependencies": {
		"@typescript-eslint/parser": "^7.15.0",
		"concurrently": "^9.1.2",
		"eslint": "^8.56.0",
		"eslint-plugin-n8n-nodes-base": "^1.16.1",
		"gulp": "^4.0.2",
		"nodemon": "^3.1.9",
		"prettier": "^3.3.2",
		"typescript": "^5.5.3"
	},
	"optionalDependencies": {
		"sharp": "^0.32.1"
	},
	"peerDependencies": {
		"n8n-core": ">=1.0.0",
		"n8n-workflow": ">=1.0.0"
	},
	"dependencies": {
		"axios": "^1.8.4",
		"pnpm": "^10.6.5",
		"zalo-api-final": "^2.1.0"
	}
}
